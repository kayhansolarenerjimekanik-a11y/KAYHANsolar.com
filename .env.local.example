# === KAYHAN Solar env template ===
# Copy this file to .env.local and fill values.

# Auth mode: 'demo' uses local credentials below; 'supabase' uses Supabase Auth.
AUTH_MODE=demo

# Data mode: 'demo' uses in-memory store seeded from lib/mock; 'supabase' uses Supabase.
DATA_MODE=demo

# Demo admin credentials (only used when AUTH_MODE=demo)
DEMO_ADMIN_EMAIL=admin@kayhansolar.com
DEMO_ADMIN_PASSWORD=kayhan2026

# HMAC secret for session cookie signing. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=replace-me-with-48-bytes-of-base64

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase direct Postgres connection (Transaction pooler URI from Dashboard → Settings → Database)
# Used ONLY by `pnpm run db:migrate` to apply SQL migrations. Replace [YOUR-PASSWORD].
# DATABASE_URL=postgresql://postgres.ljehpnhcqdipyqxdcwwn:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Resend (transactional email)
RESEND_API_KEY=

# Gemini (Google AI)
GEMINI_API_KEY=

# Web Push (filled later when VAPID keypair generated)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudflare Turnstile (filled later)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Production canonical URL (sitemap.xml, robots.txt, OG metadata)
# Faz 6 production deploy'unda gerçek domain ile doldurulacak.
NEXT_PUBLIC_SITE_URL=https://kayhansolar.com
